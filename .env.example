# Supabase
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJh...   # Service role key — keep secret, server-side only
SUPABASE_ANON_KEY=eyJh...           # Public anon key — safe for the browser

# Google Calendar (from Google Cloud Console → Credentials → OAuth 2.0 Client ID)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/calendar/callback

# Email / SMTP (Gmail example — use an App Password if 2FA is on)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=

PORT=3000
